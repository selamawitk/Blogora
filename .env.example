# Required: MongoDB connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/blogora?retryWrites=true&w=majority

# Required: JWT signing secret (use a long random string)
JWT_SECRET=replace_with_a_long_random_secret

# Optional: Server port (defaults to 5001)
PORT=5001

# Optional: Comma-separated allowed CORS origins (default: http://localhost:3000)
# For Netlify production, add your Netlify URL here
CLIENT_URL=http://localhost:3000,https://your-netlify-site.netlify.app
