# =============================================================================
# Blogora — Production Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Required: MongoDB Atlas Connection ---
# Get this from MongoDB Atlas > Connect > Drivers
# Replace <username>, <password>, <dbname> with your values
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/blogora?retryWrites=true&w=majority

# --- Required: JWT Signing Secret ---
# Generate a long random string (at least 32 characters)
# You can generate one with: openssl rand -base64 32
JWT_SECRET=replace_with_a_random_string_at_least_32_chars_long

# --- Server Port ---
# Render sets PORT automatically. Leave this commented to use Render's port.
# PORT=5001

# --- Allowed CORS Origins ---
# Comma-separated list of frontend URLs allowed to call the API
# For Vercel frontend + Render backend setup, set this to your Vercel domain
CLIENT_URL=https://your-vercel-app.vercel.app,http://localhost:3000,http://localhost:5173

# --- Node Environment ---
# Render sets this automatically. Override only if needed.
# NODE_ENV=production

# --- Email Configuration (Optional) ---
# For production password reset emails, configure an email provider
# See server/services/emailService.js
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.xxxxx

# --- Vercel Frontend (React) ---
# Set this in Vercel Dashboard > Environment Variables (Production)
# This must point to your Render backend API
# REACT_APP_API_URL=https://your-render-backend.onrender.com/api
